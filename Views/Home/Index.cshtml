@model QOS.Models.User
@inject Microsoft.Extensions.Localization.IStringLocalizer<QOS.SharedResource> Localizer
@{
    ViewData["Title"] = "Home";
    
    var now = DateTime.Now;
    var hour = now.Hour;
    string greeting;
    if (hour < 12)
    {
        greeting = Localizer["GoodMorning"];
    }
    else if (hour < 18)
    {
        greeting = Localizer["GoodAfternoon"];
    }
    else
    {
        greeting = Localizer["GoodEvening"];
    }

    // Fallback to English if localization key is missing
    if (string.IsNullOrWhiteSpace(greeting) || greeting == $"[{nameof(Localizer)}]")
    {
        if (hour < 12) greeting = "Good morning";
        else if (hour < 18) greeting = "Good afternoon";
        else greeting = "Good evening";
    }

    var GreetingMessage = (User?.Identity != null && User.Identity.IsAuthenticated)
        ? $"{greeting} {Model.FullName}"
        : greeting;

    ViewData["GreetingMessage"] = GreetingMessage;
    
}
@{
    var successMessage = TempData["SuccessMessage"] as string;
    var errorMessage = TempData["ErrorMessage"] as string;
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}


@* <!-- Hero Section --> *@
<div class="hero-section fade-in">
    @* <h1>Welcome to QOS Dashboard</h1> *@
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <h1>@ViewData["GreetingMessage"]</h1>
    } else {
        <h1>@Localizer["WelcomeMessage"] </h1>
    }
    <p>Your Quality Operations System at a glance</p>
    <a href="/Report" class="hero-button">@Localizer["gotoReport"]</a>
</div>

