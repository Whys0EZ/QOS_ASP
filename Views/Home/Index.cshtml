        <div class="feature-card">
            <span class="feature-icon">⚙️</span>
            <h3>@Localizer["ProcessManagement"]</h3>
            <p>@Localizer["ProcessManagement_p"]</p>
        </div>
        @* <div class="feature-card">
            <span class="feature-icon">🔔</span>
            <h3>Cảnh báo tức thì</h3>
            <p>Nhận thông báo ngay lập tức khi có sự cố hoặc chỉ số chất lượng vượt ngưỡng cho phép.</p>
        </div> *@
        <div class="feature-card">
            <span class="feature-icon">👥</span>
            <h3>@Localizer["Teamwork"]</h3>
            <p>@Localizer["Teamwork_p"]</p>
        </div>
        <div class="feature-card">
            <span class="feature-icon">🔒</span>
            <h3>@Localizer["HighSecurity"]</h3>
            <p>@Localizer["HighSecurity_p"]</p>
        </div>
        <div class="feature-card">
            <span class="feature-icon">📱</span>
            <h3>@Localizer["Multi-platform"]</h3>
            <p>@Localizer["Multi-platform_p"]</p>
        </div>
    </div>
</div>

@* <!-- About Section --> *@
<div class="about-section">
    <div class="about-grid">
        <div class="about-text">
            <h2>@Localizer["AboutSystem"]</h2>
            <p>@Localizer["AboutSystem_p1"]</p>
            <p>@Localizer["AboutSystem_p2"]</p>
            <p>@Localizer["AboutSystem_p3"]</p>
        </div>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-number">99.9%</div>
                <div class="stat-label">@Localizer["Uptime"]</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">12/7</div>
                <div class="stat-label">@Localizer["Support"]</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">1000+</div>
                <div class="stat-label">@Localizer["Users"]</div>
            </div>
        </div>
    </div>
</div>

@* <!-- Modules Section --> *@
<div class="modules-section">
    <h2 class="section-title">@Localizer["Mainfunctions"]</h2>
    <div class="modules-grid">
        <div class="module-card" onclick="location.href='/Report';" style="cursor: pointer;">
            <h3>📈 @Localizer["Report"]</h3>
            <p>@Localizer["Report_p"]</p>
        </div>
        <div class="module-card" onclick="location.href='/Function';" style="cursor: pointer;">
            <h3>📋 @Localizer["Setting"]</h3>
            <p>@Localizer["Setting_p"]</p>
        </div>
        <div class="module-card" onclick="location.href='/Setting';" style="cursor: pointer;">
            <h3>🎯 @Localizer["Function"]</h3>
            <p>@Localizer["Function_p"]</p>
        </div>
        <div class="module-card" onclick="location.href='/SystemAdmin';" style="cursor: pointer;">
            <h3>⚙️ @Localizer["System"]</h3>
            <p>@Localizer["System_p"]</p>
        </div>
    </div>
</div>

@* <!-- CTA Section --> *@
<div class="cta-section">
    <h2>@Localizer["ReadyBegin"]</h2>
    <p>@Localizer["DiscoverQOS"]</p>
    <div class="cta-buttons">
        <a href="/Report" class="btn-primary-custom">@Localizer["gotoReport"]</a>
        <a href="/Setting" class="btn-secondary-custom">@Localizer["Setting"]</a>
    </div>
</div>

@section Scripts {
    <script>
        // Intersection Observer for fade-in animations
        document.addEventListener('DOMContentLoaded', function() {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.opacity = '1';
                        entry.target.style.transform = 'translateY(0)';
                    }
                });
            }, {
                threshold: 0.1
            });

            // Observe all cards
            document.querySelectorAll('.feature-card, .module-card, .stat-card').forEach(card => {
                card.style.opacity = '0';
                card.style.transform = 'translateY(20px)';
                card.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
                observer.observe(card);
            });
        });

        // Refresh the page when the hour changes (keeps greeting/time-sensitive UI up to date)
        (function() {
            const initialHour = new Date().getHours();

            function checkHourAndReload() {
                const currentHour = new Date().getHours();
                // console.log("currentHour: " + currentHour + " initialHour: " + initialHour)
                if (currentHour !== initialHour) {
                    // reload to re-evaluate server-side greeting/localization
                    location.reload();
                }
            }

            // Align first check to the start of the next minute, then check every minute
            const now = new Date();
            const msToNextMinute = (60 - now.getSeconds()) * 1000 - now.getMilliseconds();
            setTimeout(() => {
                checkHourAndReload();
                setInterval(checkHourAndReload, 60 * 1000);
            }, msToNextMinute);
        })();
    </script>
}