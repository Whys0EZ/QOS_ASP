@model QOS.Models.Factory_List
@inject Microsoft.Extensions.Localization.IStringLocalizer<QOS.SharedResource> Localizer
@inject Microsoft.Extensions.Localization.IStringLocalizer<QOS.Areas.Setting.SharedResource> SetLocalizer
@{
    Layout = "_MenuSetting";
    ViewData["Title"] = SetLocalizer["EditFactory"];
}
<partial name="_AlertMessage" />
<div class=" m-3 ">
    <h2  class="text-uppercase">@SetLocalizer["EditFactory"]</h2>

    <form asp-action="EditFactory" method="post" class="mb-3">
       <div class="form-group mb-2">
            <label>@SetLocalizer["FactoryCode"]</label>
            <input asp-for="FactoryID" class="form-control"  readonly  />
        </div>
        <div class="form-group mb-2">
            <label>@SetLocalizer["FactoryName"]</label>
            <input asp-for="FactoryName" class="form-control" />
        </div>
        <div class="form-group mb-2">
            <label>@Localizer["Remark"]</label>
            <input asp-for="Remark" class="form-control" />
        </div>
        
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-success mt-4">@Localizer["Save"]</button>
            <button type="submit" form="deleteForm" class="btn btn-danger mt-4"> @Localizer["Delete"] </button>
            <a asp-action="Index" class="btn btn-secondary mt-4">@Localizer["Cancel"]</a>
        </div>

    </form>

    <!-- FORM DELETE -->
    <form id="deleteForm" asp-action="DeleteFactory" asp-controller="Setting" asp-area="Setting"
          method="post"
          onsubmit="return confirm('Bạn có chắc muốn xóa?')">

       
        <input type="hidden" asp-for="FactoryID" />

    </form>
</div>