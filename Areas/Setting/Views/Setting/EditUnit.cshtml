@model QOS.Models.Unit_List
@inject Microsoft.Extensions.Localization.IStringLocalizer<QOS.SharedResource> Localizer
@inject Microsoft.Extensions.Localization.IStringLocalizer<QOS.Areas.Setting.SharedResource> SetLocalizer
@{
    Layout = "_MenuSetting";
    ViewData["Title"] = SetLocalizer["EditUnit"];
}

<div class=" m-3 ">
    <h2 class="text-uppercase">@SetLocalizer["EditUnit"]</h2>

    <form asp-action="EditUnit" method="post" class="mb-3">
        <div class="form-group mb-2">
            <label>@Localizer["Factory"]</label>
            <input asp-for="Factory" class="form-control" />
        </div>
        <div class="form-group mb-2">
            <label>@Localizer["Zone"]</label>
            <input asp-for="Zone" class="form-control" />
        </div>
        <div class="form-group mb-2">
            <label>Block</label>
            <input asp-for="Block" class="form-control" />
        </div>
        <div class="form-group mb-2">
            <label>@Localizer["Unit"]</label>
            <input asp-for="Unit" class="form-control" />
        </div>
        <div class="form-group mb-2">
            <label>Act</label>
            <input asp-for="Act" class="form-control" />
        </div>
        <div class="form-group mb-2">
            <label>ETS_SUB</label>
            <input asp-for="ETS_SUB" class="form-control" />
        </div>
        @* <div class="form-group">
            <label>Password</label>
            <input asp-for="Pass" type="password" class="form-control" />
        </div>
         *@

        
        
        <button type="submit" class="btn btn-success mt-4">@Localizer["Save"]</button>
        <button type="submit" form="deleteForm" class="btn btn-danger mt-4"> @Localizer["Delete"] </button>
        <a asp-action="UnitList" class="btn btn-secondary mt-4">@Localizer["Back"]</a>

    </form>

    <!-- FORM DELETE -->
    <form id="deleteForm" asp-action="DeleteUnit" asp-controller="Setting" asp-area="Setting"
          method="post"
          onsubmit="return confirm('Bạn có chắc muốn xóa?')">

       
        <input type="hidden" asp-for="Unit" />

    </form>
</div>